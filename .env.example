NODE_ENV=development
PORT=3000
API_PORT_MAPPING=3000:3000
TZ=Asia/Shanghai
ADMIN_BASIC_AUTH_USER=
ADMIN_BASIC_AUTH_PASSWORD=

CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=hotspot
CLICKHOUSE_API_PASSWORD=

POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=hotspot
POSTGRES_URL=

REDIS_URL=

ALERT_WEBHOOK_URL=
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=
FEISHU_BITABLE_APP_TOKEN=
FEISHU_BITABLE_BASE_URL=
FEISHU_BITABLE_ACTION_TABLE_NAME=投放执行表

# Pull API global bearer token (optional for MVP puller)
APPSFLYER_PULL_TOKEN=
APPSFLYER_PULL_ENDPOINT_TEMPLATE=https://hq1.appsflyer.com/api/agg-data/export/app/{app_id}/daily_report/v5
APPSFLYER_MASTER_API_TOKEN=
BI_APPSFLYER_RAWDATA_TOKEN=
APPSFLYER_RAWDATA_ENDPOINT_TEMPLATE=https://hq1.appsflyer.com/api/raw-data/export/app/{app_id}/in_app_events_report/v5
APPSFLYER_RAW_INSTALLS_ENDPOINT_TEMPLATE=https://hq1.appsflyer.com/api/raw-data/export/app/{app_id}/installs_report/v5
APPSFLYER_RAW_EVENTS_ENDPOINT_TEMPLATE=https://hq1.appsflyer.com/api/raw-data/export/app/{app_id}/in_app_events_report/v5
APPSFLYER_COHORT_ENDPOINT_TEMPLATE=https://hq1.appsflyer.com/api/cohorts/v1/data/app/{app_id}
APPSFLYER_COHORT_TIMEOUT_MS=20000
APPSFLYER_COHORT_REQUEST_INTERVAL_MS=1000

# Worker tunables
AGGREGATOR_LOOKBACK_HOURS=6
AGGREGATOR_INTERVAL_MS=300000
DETECTOR_INTERVAL_MS=300000
PULLER_INTERVAL_MS=86400000
PULLER_REPORT_HOUR=9
PULLER_BACKFILL_DAYS=3
PULLER_RUN_ON_BOOT=false
PULLER_REQUEST_INTERVAL_MS=1000
PULLER_LOCK_TTL_MS=900000
PULLER_SAME_CONTENT_COOLDOWN_RECENT_MS=7200000
PULLER_SAME_CONTENT_COOLDOWN_HISTORICAL_MS=86400000

# Keyword lifecycle + budget advisor workers
KEYWORD_ENGINE_INTERVAL_MS=86400000
KEYWORD_ENGINE_INITIAL_BACKFILL_DAYS=30
KEYWORD_ENGINE_ROLLING_BACKFILL_DAYS=3
BUDGET_ADVISOR_INTERVAL_MS=86400000
BUDGET_ADVISOR_LOOKBACK_DAYS=30
ASA_KEYWORD_INTERVAL_MS=86400000
ASA_KEYWORD_REPORT_HOUR=9
ASA_KEYWORD_BACKFILL_DAYS=14
ASA_KEYWORD_RUN_ON_BOOT=false
ASA_KEYWORD_REQUEST_INTERVAL_MS=1200
ASA_RECOMMENDATION_LLM_CONCURRENCY=12
ASA_MASTER_API_REQUEST_INTERVAL_MS=1200
ASA_DAILY_BRIEF_ENABLED=true
ASA_DAILY_BRIEF_INTERVAL_MS=3600000
ASA_DAILY_BRIEF_REPORT_HOUR=10
FEISHU_BITABLE_ENABLED=false
FEISHU_BITABLE_SCHEDULE_HOUR=10
FEISHU_BITABLE_SCHEDULE_MINUTE=5
DAILY_BRIEF_ENABLED=true
DAILY_BRIEF_INTERVAL_MS=3600000
DAILY_BRIEF_REPORT_HOUR=10
DAILY_BRIEF_TITLE_PREFIX=Hotspot 每日简报

# Qwen (OpenAI compatible API)
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3.6-plus
QWEN_THINKING_ENABLED=true
QWEN_TIMEOUT_MS=15000
QWEN_MAX_TOKENS=1200

# OpenRouter (Guru Ads Agent optional provider, e.g. Kimi-K2.5)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_API_KEY=
OPENROUTER_MODEL=moonshotai/kimi-k2.5
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=
OPENROUTER_TIMEOUT_MS=15000
OPENROUTER_MAX_TOKENS=1200

# OpenAI official API (Guru Ads Agent optional provider)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
OPENAI_TIMEOUT_MS=15000
OPENAI_MAX_TOKENS=1200

# Internal MCP bridge (Guru Ads Agent context packs)
MCP_BIND_HOST=127.0.0.1
MCP_PORT=3100
MCP_BASE_URL=http://127.0.0.1:3100/mcp
MCP_TIMEOUT_MS=15000
MCP_INTERNAL_TOKEN=dev-hotspot-mcp-token

# ROAS 成本覆盖率阈值（默认 0.8 即 80%）
# 当成熟窗口内 cohort 数据覆盖的成本占比低于此值时，ROAS/CPP 显示"待补齐"
ROAS_COST_COVERAGE_THRESHOLD=0.8
