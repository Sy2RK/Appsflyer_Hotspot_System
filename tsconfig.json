{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": ".",
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["packages/shared/*"],
      "@api/*": ["apps/api/src/*"]
    },
    "outDir": "dist"
  },
  "include": ["apps", "workers", "packages"],
  "exclude": ["node_modules", "dist"]
}
